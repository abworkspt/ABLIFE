{
  "name": "myapp",
  "version": "0.1.0",
  "description": "App pessoal - Gestão financeira, tarefas, calendário e notas",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.myapp.personal",
    "productName": "MyApp",
    "directories": { "output": "dist" },
    "extraResources": [{ "from": "node_modules/sql.js/dist/sql-wasm.wasm", "to": "sql-wasm.wasm" }],
    "win": { "target": "portable" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  }
}
